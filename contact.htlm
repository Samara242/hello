<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="boot/css/bootstrap.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="style.css">
    <title>Document</title>
</head>
<body style="background-image: url(D.jpg);" class="info">
   
    <fieldset class="border p-4 rounded">
       <div class="row">
           <div class="col-12 cold-md-6">
               <legend class="w-auto px-2" ><span class="fw-bold bg-primary text-white p-1">Pour toutes vos préoccupations et suggestions CONTACTEZ-Nous !</span> 
               </legend><br>
            </div>
           </div>

      <form method="post" attribut="" class="container col-12 cold-md-5 mx-auto">
        <div class="row">
           <div class="col-12 cold-md-4">
              <label for="Nom">Nom:</label> <input type="text" class="form-control" name="Nom" id="Nom"></br><br> 
            </div>

           <div class="col-12 cold-md-4"></div>
             <label for="Prénom">Prénom:</label> <input type="text" class="form-control" name="prénom" id="prenom"></br><br>
            </div>
          
             <div class="col-12 cold-md-4"> 
               <label for="Commentaire">Commentaire:</label><input  type="textarea" class="form-control" name="Commentaire" id="Commentaire"><br><br>
              </div>

              <div class="col-12 cold-md-4">
               <label for="Email">Votre Email:</label> <input type="email" class="form-control" name="Email" id="Email"></br><br>
              </div>

              <div class="col-12 cold-md-4"><label for="Tél">Tél:</label> <input type="tel" class="form-control"
                name="Tél" id="Tél"></br>
              </div>
         </div>
          <button ty="submit" class="btn btn-primary">Envoyer</button>
       </form>
     </fieldset>

     <div class="row">
            <div class="col-12 cold-md-6">
              <h3> 
              A PROPOS: Nous sommes le groupe <span class=text-decoration>Elites CODEURS</span>  près à vous aider à devenir des experts du WEB.
            </h3>
              <p><a href="index.html" class="btn btn-primary">Retour à l'Acceuil</a></p>
            </div>
           </div>
      
    <script src=boot/js/bootstrap.bundle.min.js></script> 
</body>
</html>
